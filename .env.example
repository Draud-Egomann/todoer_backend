# Example environment variables for Todoer Backend
# Copy this to .env and adjust values as needed

# Server Configuration
PORT=3000
ENV=development

# Database Configuration  
# For development use relative path: todoer.db
# For Docker use: /root/data/todoer.db
DB_PATH=todoer.db

# Authentication - CHANGE THIS IN PRODUCTION!
# Use a strong, random string in production
API_KEY=todo-secret-api-key-change-in-production
